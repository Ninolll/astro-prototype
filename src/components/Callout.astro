---
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<aside class="callout">
  <strong>{title}</strong>
  <slot />
</aside>

<style>
  .callout {
    border-left: 4px solid #ff5d01;
    background: #fff7ed;
    padding: 1rem;
    margin: 1.5rem 0;
  }

  .callout strong {
    display: block;
    margin-bottom: 0.5rem;
  }
</style>